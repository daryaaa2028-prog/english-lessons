
<style>
#ls{--bg:#f4f4fb;--sf:#fff;--sf2:#edeef8;--bd:#d8d9ee;--ac:#7c3aed;--tx:#1a1a30;--mu:#6b6b8a;--ok:#16a34a;--ok2:rgba(22,163,74,.1);--er:#dc2626;--er2:rgba(220,38,38,.1);font-family:'Segoe UI',-apple-system,sans-serif;color:var(--tx);background:var(--bg)}
#ls *{box-sizing:border-box;margin:0;padding:0}
#ls header{background:#1a1a30;border-bottom:2px solid var(--ac);padding:12px 20px;display:flex;align-items:center;justify-content:space-between;border-radius:12px 12px 0 0}
#ls .logo{font-size:.9rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:#c4b5fd}
#ls .logo em{color:#fff;font-style:normal}
#ls .pw{display:flex;gap:6px;align-items:center;flex-wrap:wrap}
#ls .ps{display:flex;align-items:center;gap:3px;cursor:pointer;padding:3px 7px;border-radius:20px;font-size:.65rem;font-weight:700;letter-spacing:.5px;color:#9090b8;transition:background .2s}
#ls .ps:hover{background:rgba(255,255,255,.1)}
#ls .ps .dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.2);flex-shrink:0}
#ls .ps.active{color:#c4b5fd}
#ls .ps.active .dot{background:#c4b5fd}
#ls .ps.done{color:#6ee7b7}
#ls .ps.done .dot{background:#6ee7b7}
#ls main{max-width:820px;margin:0 auto;padding:32px 20px 48px}
#ls .page{display:none}
#ls .page.active{display:block;animation:fu .3s ease}
@keyframes fu{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
#ls .tag{display:inline-block;font-size:.62rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--ac);background:rgba(124,58,237,.08);border:1px solid rgba(124,58,237,.25);padding:3px 12px;border-radius:20px;margin-bottom:12px}
#ls h1{font-size:1.7rem;font-weight:800;line-height:1.2;margin-bottom:8px;color:var(--tx)}
#ls .sub{color:var(--mu);font-size:.92rem;margin-bottom:28px;line-height:1.6;max-width:580px}
#ls .card{background:var(--sf);border:1px solid var(--bd);border-radius:12px;padding:20px 24px;margin-bottom:18px}
#ls .clb{font-size:.65rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--mu);margin-bottom:16px}
#ls .gb{background:linear-gradient(135deg,#1a1a30,#1a2535);border:1px solid rgba(124,58,237,.3);border-radius:12px;padding:20px 24px;margin-bottom:18px;color:#e8e8f8}
#ls .gb h3{color:#c4b5fd;font-size:.75rem;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:14px}
#ls table{width:100%;border-collapse:collapse;font-size:.88rem}
#ls th{background:rgba(196,181,253,.15);color:#c4b5fd;padding:9px 12px;text-align:left;font-size:.65rem;letter-spacing:1.5px;text-transform:uppercase}
#ls td{padding:9px 12px;border-bottom:1px solid rgba(255,255,255,.1);line-height:1.5;color:#e8e8f8}
#ls tr:last-child td{border-bottom:none}
#ls .hl{color:var(--ac);font-weight:700}
#ls .ex{background:var(--sf2);border-left:3px solid var(--ac);border-radius:0 7px 7px 0;padding:9px 14px;margin:6px 0;font-size:.9rem;line-height:1.6;font-style:italic;color:var(--tx)}
#ls .disc{display:flex;gap:12px;padding:12px 0;border-bottom:1px solid var(--bd);align-items:flex-start;line-height:1.6;font-size:.9rem}
#ls .disc:last-child{border-bottom:none}
#ls .di{font-size:1.1rem;flex-shrink:0;margin-top:1px}
#ls .qr{display:flex;gap:12px;margin-bottom:18px;align-items:flex-start;line-height:1.7;font-size:.9rem}
#ls .qr:last-child{margin-bottom:0}
#ls .qn{width:26px;height:26px;min-width:26px;background:var(--ac);color:#fff;border-radius:50%;font-size:.75rem;font-weight:800;display:flex;align-items:center;justify-content:center;margin-top:2px}
#ls .blank{display:inline-block;min-width:80px;border:none;border-bottom:2px solid var(--ac);background:transparent;color:var(--tx);font-size:.9rem;padding:1px 5px;text-align:center;outline:none;font-family:inherit}
#ls .blank.ok{border-color:var(--ok);color:var(--ok)}
#ls .blank.err{border-color:var(--er);color:var(--er)}
#ls input.li,#ls textarea.li{width:100%;background:var(--sf2);border:2px solid var(--bd);color:var(--tx);padding:9px 14px;border-radius:9px;font-size:.88rem;font-family:inherit;outline:none;line-height:1.6;margin-top:7px}
#ls textarea.li{resize:vertical;min-height:50px}
#ls input.li:focus,#ls textarea.li:focus{border-color:var(--ac)}
#ls select.sel{background:var(--sf2);border:2px solid var(--bd);color:var(--tx);padding:7px 11px;border-radius:8px;font-size:.88rem;cursor:pointer;width:100%;outline:none;font-family:inherit}
#ls select.sel:focus{border-color:var(--ac)}
#ls select.sel.ok{border-color:var(--ok)}
#ls select.sel.err{border-color:var(--er)}
#ls .mr{display:grid;grid-template-columns:160px 1fr;gap:12px;align-items:center;margin-bottom:10px}
#ls .ml{font-weight:600;font-size:.88rem}
#ls .opts{display:flex;flex-wrap:wrap;gap:8px;margin-top:7px;margin-left:38px}
#ls .opt{padding:5px 18px;border:2px solid var(--bd);border-radius:20px;cursor:pointer;font-size:.84rem;font-weight:600;background:var(--sf);color:var(--tx);transition:all .18s;user-select:none}
#ls .opt:hover{border-color:var(--ac);color:var(--ac)}
#ls .opt.ok{border-color:var(--ok);background:var(--ok2);color:var(--ok);pointer-events:none}
#ls .opt.err{border-color:var(--er);background:var(--er2);color:var(--er);pointer-events:none}
#ls .opt.disabled{pointer-events:none;opacity:.45}
#ls .btn{display:inline-flex;align-items:center;gap:7px;padding:9px 22px;border-radius:9px;font-size:.86rem;font-weight:700;cursor:pointer;border:none;font-family:inherit;transition:all .18s}
#ls .bg{background:var(--ac);color:#fff}
#ls .bg:hover{background:#6d28d9}
#ls .bo{background:transparent;border:2px solid var(--bd);color:var(--tx)}
#ls .bo:hover{border-color:var(--mu)}
#ls .fb{padding:10px 16px;border-radius:9px;font-size:.86rem;margin-top:14px;line-height:1.6;display:none}
#ls .fb.show{display:block}
#ls .fb.good{background:var(--ok2);border:1px solid var(--ok);color:var(--ok)}
#ls .fb.bad{background:var(--er2);border:1px solid var(--er);color:var(--er)}
#ls .fb.neu{background:var(--sf2);border:1px solid var(--bd);color:var(--tx)}
#ls .fg{display:grid;grid-template-columns:repeat(auto-fill,minmax(165px,1fr));gap:12px;margin-top:14px}
#ls .fc{background:var(--sf2);border:1px solid var(--bd);border-radius:11px;padding:16px;cursor:pointer;transition:all .2s}
#ls .fc:hover{border-color:var(--ac);transform:translateY(-2px)}
#ls .fc .fe{font-size:1.7rem;margin-bottom:6px}
#ls .fc .fn{font-weight:700;font-size:.84rem;margin-bottom:2px}
#ls .fc .fy{font-size:.74rem;color:var(--mu);margin-bottom:8px}
#ls .fc .fh{font-size:.78rem;color:var(--mu);max-height:0;overflow:hidden;transition:max-height .3s;line-height:1.5}
#ls .fc.open .fh{max-height:200px}
#ls .fc .ft{font-size:.72rem;color:var(--ac);margin-top:7px}
#ls .nav{display:flex;justify-content:space-between;align-items:center;margin-top:36px;padding-top:20px;border-top:1px solid var(--bd)}
#ls .pc{font-size:.8rem;color:var(--mu)}
@media(max-width:540px){#ls h1{font-size:1.3rem}#ls main{padding:20px 14px 36px}#ls .mr{grid-template-columns:1fr}#ls .fg{grid-template-columns:1fr 1fr}}
</style>

